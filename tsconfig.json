{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "commonjs",
    "target": "esnext",

    // 1. REMOVE "types": [] or add "express" and "node"
    "types": ["node", "express"],

    // 2. ADD typeRoots to tell TS where to look for your custom definitions
    "typeRoots": ["./node_modules/@types", "./src/types"],

    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
