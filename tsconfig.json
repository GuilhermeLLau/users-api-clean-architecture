{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "commonjs",
    "target": "esnext",
    "outDir": "./dist",
    "types": ["node", "express"],
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
